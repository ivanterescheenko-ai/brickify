# === Component Search (all optional) ===

# Octopart — electronic components aggregator (DigiKey, Mouser, Arrow, etc.)
# Free: 100 requests/hour. Get key: https://octopart.com/api/register
OCTOPART_API_KEY=

# Tavily — general web search for non-electronic parts
# Free: 1000 searches/month. Get key: https://tavily.com
TAVILY_API_KEY=

# CORS
ALLOWED_ORIGINS=

# Timeout pipeline в секундах
PIPELINE_TIMEOUT=180
